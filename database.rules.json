{
  "rules": {
    "matches": {
      "$matchId": {
        "meta": {
          ".read": "auth != null && (data.child('player1Uid').val() === auth.uid || data.child('player2Uid').val() === auth.uid)",
          ".write": false
        },
        "state": {
          ".read": "auth != null && (root.child('matches').child($matchId).child('meta').child('player1Uid').val() === auth.uid || root.child('matches').child($matchId).child('meta').child('player2Uid').val() === auth.uid)",
          ".write": false
        },
        "private": {
          ".read": false,
          ".write": false
        },
        "commands": {
          "$commandId": {
            ".read": "auth != null && (root.child('matches').child($matchId).child('meta').child('player1Uid').val() === auth.uid || root.child('matches').child($matchId).child('meta').child('player2Uid').val() === auth.uid)",
            ".write": "auth != null && (root.child('matches').child($matchId).child('meta').child('player1Uid').val() === auth.uid || root.child('matches').child($matchId).child('meta').child('player2Uid').val() === auth.uid)",
            ".validate": "newData.hasChildren(['type', 'playerUid', 'timestamp', 'payload']) && newData.child('type').isString() && newData.child('playerUid').isString() && newData.child('timestamp').isNumber() && newData.child('playerUid').val() === auth.uid"
          }
        },
        "timers": {
          ".read": "auth != null",
          ".write": false
        },
        "log": {
          ".read": "auth != null && (root.child('matches').child($matchId).child('meta').child('player1Uid').val() === auth.uid || root.child('matches').child($matchId).child('meta').child('player2Uid').val() === auth.uid)",
          ".write": false
        }
      }
    },
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}
